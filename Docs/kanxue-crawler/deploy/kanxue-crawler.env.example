# SMTP 凭证给 systemd unit 用。chmod 600。
# 路径：/etc/kanxue-crawler.env

# 必填
KANXUE_SMTP_HOST=smtp.qq.com
KANXUE_SMTP_PORT=465
KANXUE_SMTP_USER=your-mail@qq.com
# 不是登录密码，是"应用专用密码 / 授权码"
KANXUE_SMTP_PASS=
KANXUE_NOTIFY_TO=your-mail@qq.com

# 可选
# KANXUE_SMTP_FROM=your-mail@qq.com
# KANXUE_SMTP_STARTTLS=0   # qq/163/gmail 都用 SSL(465)，写 0 即可；用 587 端口才设成 1
